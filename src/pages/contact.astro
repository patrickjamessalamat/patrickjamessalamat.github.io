---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title={`Contact · ${site.name}`} description={`How to get in touch with ${site.name}.`}>
  <div class="mx-auto max-w-[1012px] px-4 py-6">
    <div class="border-b border-line pb-4">
      <h1 class="text-xl font-semibold">Get in touch</h1>
      <p class="mt-1 text-sm text-muted">
        I’m open to opportunities, collaborations, and interesting conversations.
      </p>
    </div>
    <div class="mt-6 box">
      <div class="box-body grid gap-4">
        <p class="text-muted">The fastest way to reach me is by email.</p>
        <div class="flex flex-wrap gap-2">
          <a class="btn btn-primary" href={`mailto:${site.email}`}>{site.email}</a>
          {site.socials.map((social) => (
            <a class="btn" href={social.url} target="_blank" rel="noopener noreferrer">
              {social.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { skills } from '../data/skills';
import { site } from '../data/site';
---

<BaseLayout title={`Stacks · ${site.name}`} description={`Technologies and tools ${site.name} works with.`}>
  <div class="mx-auto max-w-[1012px] px-4 py-6">
    <div class="border-b border-line pb-4">
      <h1 class="text-xl font-semibold">Stacks</h1>
      <p class="mt-1 text-sm text-muted">Technologies and tools I work with.</p>
    </div>
    <div class="mt-6 grid grid-cols-1 items-start gap-4 md:grid-cols-2">
      {skills.map((group) => (
        <div class="box">
          <div class="box-header">{group.category.toLowerCase().replace(/[^a-z0-9]+/g, '-')}.md</div>
          <div class="box-body">
            <ul class="flex flex-wrap gap-1.5">
              {group.items.map((item) => (
                <li class="topic">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

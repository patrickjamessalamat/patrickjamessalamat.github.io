---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Readme from '../components/Readme.astro';
import ContributionGraph from '../components/ContributionGraph.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout>
  <div class="mx-auto grid max-w-[1216px] grid-cols-1 gap-6 px-4 py-6 md:grid-cols-[296px_minmax(0,1fr)]">
    <Sidebar />
    <div class="grid gap-6">
      <Readme />
      <ContributionGraph />
      <Projects />
      <Skills />
      <Experience />
      <Contact />
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Readme from '../components/Readme.astro';
import ContributionGraph from '../components/ContributionGraph.astro';
import Projects from '../components/Projects.astro';
---

<BaseLayout title="Patrick Salamat - AI & .NET Software Engineer">
  <div class="mx-auto grid max-w-[1216px] grid-cols-1 gap-6 px-4 py-6 md:grid-cols-[296px_minmax(0,1fr)]">
    <Sidebar />
    {/* grid-cols-1 compiles to minmax(0,1fr). Without an explicit track the
        implicit one is `auto`, which sizes to max-content — the contribution
        graph would then stretch every card here past the viewport. */}
    <div class="grid min-w-0 grid-cols-1 gap-6">
      <Readme />
      <ContributionGraph />
      <Projects />
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Role from '../components/Role.astro';
import { experience } from '../data/experience';
import { site } from '../data/site';

const work = experience.filter((entry) => entry.kind === 'work');
const education = experience.filter((entry) => entry.kind === 'education');

const sections = [
  { title: 'work', entries: work },
  { title: 'education', entries: education },
].filter((section) => section.entries.length > 0);
---

<BaseLayout title={`Experience · ${site.name}`} description={`Where ${site.name} has worked and studied.`}>
  <div class="mx-auto max-w-[900px] px-4 py-8">
    <div class="border-b border-line pb-4">
      <h1 class="text-xl font-semibold">Experience</h1>
      <p class="mt-1 text-sm text-muted">Where I’ve worked and studied.</p>
    </div>

    {sections.map((section) => (
      <section class="mt-8">
        <h2 class="mb-4 font-mono text-sm text-muted">{section.title}.md</h2>
        <ol class="grid gap-4">
          {section.entries.map((entry) => (
            <li class="box">
              <div class="box-body">
                {entry.roles.length === 1 ? (
                  <Role role={entry.roles[0]} organization={entry.organization} location={entry.location} />
                ) : (
                  <>
                    {/* Company header, styled like the single-role card */}
                    <div>
                      <h3 class="text-lg font-semibold leading-snug">{entry.headline ?? entry.organization}</h3>
                      <p class="text-sm">
                        <span class="font-medium text-accent">{entry.organization}</span>
                        {entry.location && <span class="text-muted"> · {entry.location}</span>}
                      </p>
                      {entry.tenure && <p class="text-sm text-muted">{entry.tenure}</p>}
                    </div>
                    <ol class="mt-4 grid gap-6 border-l border-line pl-6">
                      {entry.roles.map((role) => (
                        <li class="relative before:absolute before:-left-[27px] before:top-1.5 before:h-2.5 before:w-2.5 before:rounded-full before:border-2 before:border-canvas before:bg-muted before:content-['']">
                          <Role role={role} />
                        </li>
                      ))}
                    </ol>
                  </>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</BaseLayout>

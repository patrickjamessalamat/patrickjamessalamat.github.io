---
// GitHub-style contribution grid, but the cells spell out "SFTWR ENGR"
// instead of carrying activity data. Rendered at build time — no client JS.
import { projectCount } from '../data/projects';
import { site } from '../data/site';

// Recomputed on every build, so the heading never goes stale.
const careerStart = new Date(`${site.careerStart}-01T00:00:00`);
const yearsExperience = Math.floor(
  (Date.now() - careerStart.getTime()) / (365.25 * 24 * 60 * 60 * 1000),
);

const WEEKS = 52; // grid columns
const DAYS = 7; // grid rows

// 5-row bitmap font. Most glyphs are 4 columns wide; W needs 5 to stay legible.
// '#' is a lit cell. Keep every row of a glyph the same length.
const GLYPHS: Record<string, string[]> = {
  S: ['.###', '#...', '.##.', '...#', '###.'],
  F: ['####', '#...', '###.', '#...', '#...'],
  T: ['####', '.##.', '.##.', '.##.', '.##.'],
  W: ['#...#', '#...#', '#.#.#', '##.##', '#...#'],
  R: ['###.', '#..#', '###.', '#.#.', '#..#'],
  E: ['####', '#...', '###.', '#...', '####'],
  N: ['#..#', '##.#', '####', '#.##', '#..#'],
  G: ['.###', '#...', '#.##', '#..#', '.###'],
  ' ': ['.', '.', '.', '.', '.'],
};

const TEXT = 'SFTWR ENGR';
const GLYPH_ROWS = 5;
const TOP = 1; // vertical offset, leaving one blank row above and below

// Seeded PRNG so the pattern is identical on every build.
function mulberry32(seed: number) {
  return () => {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(20260721);

// Letters vary across the darker steps and the background carries sparse light
// cells, so the word reads as activity data rather than a banner.
const litLevel = () => {
  const roll = rand();
  if (roll < 0.2) return 2;
  if (roll < 0.55) return 3;
  return 4;
};
const backgroundLevel = () => (rand() < 0.22 ? 1 : 0);

const blankColumn = () => Array.from({ length: DAYS }, backgroundLevel);

// Lay the glyphs out left to right with a one-column gap between them.
const letters: number[][] = [];
for (const char of TEXT) {
  const glyph = GLYPHS[char];
  for (let x = 0; x < glyph[0].length; x++) {
    const column = blankColumn();
    for (let y = 0; y < GLYPH_ROWS; y++) {
      if (glyph[y][x] === '#') column[TOP + y] = litLevel();
    }
    letters.push(column);
  }
  letters.push(blankColumn());
}
letters.pop(); // drop the trailing gap

// Centre the word in the 52-week grid.
const leading = Math.max(0, Math.floor((WEEKS - letters.length) / 2));
const weeks = [...Array.from({ length: leading }, blankColumn), ...letters].slice(0, WEEKS);
while (weeks.length < WEEKS) weeks.push(blankColumn());

const cellClass =
  'h-2.5 w-2.5 rounded-[2px] outline-1 -outline-offset-1 outline-[rgba(27,31,35,0.06)]';
---

<section aria-label="Decorative contribution graph">
  <h2 class="section-heading">
    {projectCount} projects in the last {yearsExperience} years
  </h2>
  <div class="box p-4">
    <div class="scroll-slim overflow-x-auto pb-1">
      <div
        class="flex w-max gap-[3px]"
        role="img"
        aria-label={`Grid of squares in the style of a GitHub contribution calendar, arranged to spell "${TEXT}". Decorative only.`}
      >
        {weeks.map((days) => (
          <div class="flex flex-col gap-[3px]">
            {days.map((level) => (
              <span class={cellClass} style={`background:var(--contrib-${level})`}></span>
            ))}
          </div>
        ))}
      </div>
    </div>
    <div class="mt-2 flex items-center justify-end gap-1 text-xs text-muted">
      Less
      {[0, 1, 2, 3, 4].map((level) => (
        <span class={cellClass} style={`background:var(--contrib-${level})`}></span>
      ))}
      More
    </div>
  </div>
</section>

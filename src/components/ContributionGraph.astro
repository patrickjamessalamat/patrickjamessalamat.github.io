---
// Decorative, GitHub-style contribution graph with deterministic placeholder
// data (seeded PRNG, generated at build time — no client JS).
const WEEKS = 52;
const DAYS = 7;

function mulberry32(seed: number) {
  return () => {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(20260719);
const weeks: number[][] = [];
let total = 0;
for (let week = 0; week < WEEKS; week++) {
  const days: number[] = [];
  // gets gradually busier toward the present, quieter on "weekends"
  const busyness = 0.35 + (week / WEEKS) * 0.45;
  for (let day = 0; day < DAYS; day++) {
    const weekend = day === 0 || day === 6;
    const roll = rand() * (weekend ? 0.55 : 1);
    let level = 0;
    if (roll > 1 - busyness) {
      level = 1 + Math.floor(rand() * 4);
      if (level > 4) level = 4;
    }
    total += level;
    days.push(level);
  }
  weeks.push(days);
}

const cellClass =
  'h-2.5 w-2.5 rounded-[2px] outline-1 -outline-offset-1 outline-[rgba(27,31,35,0.06)]';
---

<section aria-label="Decorative contribution graph">
  <h2 class="section-heading">
    {total} contributions in the last year
    <span class="text-xs font-normal text-muted">(placeholder)</span>
  </h2>
  <div class="box p-4">
    <div class="overflow-x-auto">
      <div
        class="flex w-max gap-[3px]"
        role="img"
        aria-label="Grid of green squares in the style of a GitHub contribution calendar. Decorative only."
      >
        {weeks.map((days) => (
          <div class="flex flex-col gap-[3px]">
            {days.map((level) => (
              <span class={cellClass} style={`background:var(--contrib-${level})`}></span>
            ))}
          </div>
        ))}
      </div>
    </div>
    <div class="mt-2 flex items-center justify-end gap-1 text-xs text-muted">
      Less
      {[0, 1, 2, 3, 4].map((level) => (
        <span class={cellClass} style={`background:var(--contrib-${level})`}></span>
      ))}
      More
    </div>
  </div>
</section>

---
// Decorative, GitHub-style contribution graph with deterministic placeholder
// data (seeded PRNG, generated at build time — no client JS).
const WEEKS = 52;
const DAYS = 7;

function mulberry32(seed: number) {
  return () => {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(20260719);
const weeks: number[][] = [];
let total = 0;
for (let week = 0; week < WEEKS; week++) {
  const days: number[] = [];
  // gets gradually busier toward the present, quieter on "weekends"
  const busyness = 0.35 + (week / WEEKS) * 0.45;
  for (let day = 0; day < DAYS; day++) {
    const weekend = day === 0 || day === 6;
    const roll = rand() * (weekend ? 0.55 : 1);
    let level = 0;
    if (roll > 1 - busyness) {
      level = 1 + Math.floor(rand() * 4);
      if (level > 4) level = 4;
    }
    total += level;
    days.push(level);
  }
  weeks.push(days);
}
---

<section class="contrib" aria-label="Decorative contribution graph">
  <h2 class="section-heading">{total} contributions in the last year <span class="text-muted note">(placeholder)</span></h2>
  <div class="box graph-box">
    <div class="graph-scroll">
      <div class="graph" role="img" aria-label="Grid of green squares in the style of a GitHub contribution calendar. Decorative only.">
        {weeks.map((days) => (
          <div class="week">
            {days.map((level) => <span class={`cell level-${level}`}></span>)}
          </div>
        ))}
      </div>
    </div>
    <div class="legend text-muted">
      Less
      {[0, 1, 2, 3, 4].map((level) => <span class={`cell level-${level}`}></span>)}
      More
    </div>
  </div>
</section>

<style>
  .note {
    font-size: 12px;
    font-weight: 400;
  }

  .graph-box {
    padding: 16px;
  }

  .graph-scroll {
    overflow-x: auto;
  }

  .graph {
    display: flex;
    gap: 3px;
    width: max-content;
  }

  .week {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .cell {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background: var(--contrib-0);
    outline: 1px solid rgba(27, 31, 35, 0.06);
    outline-offset: -1px;
  }

  .level-1 { background: var(--contrib-1); }
  .level-2 { background: var(--contrib-2); }
  .level-3 { background: var(--contrib-3); }
  .level-4 { background: var(--contrib-4); }

  .legend {
    display: flex;
    align-items: center;
    gap: 4px;
    justify-content: flex-end;
    margin-top: 8px;
    font-size: 12px;
  }
</style>

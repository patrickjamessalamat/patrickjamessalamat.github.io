---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';

const base = import.meta.env.BASE_URL;
const pinned = projects.filter((project) => project.pinned);
---

<section>
  <div class="mb-4 flex items-baseline justify-between">
    <h2 class="text-base font-semibold">Pinned</h2>
    <a class="text-xs" href={`${base}projects/`}>View all projects →</a>
  </div>
  {/* min(280px,100%) so the track can shrink below 280px on narrow phones */}
  <div class="grid grid-cols-[repeat(auto-fill,minmax(min(280px,100%),1fr))] gap-4">
    {pinned.map((project) => <ProjectCard project={project} />)}
  </div>
</section>

---
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<section class="hero" id="top">
  <div class="container">
    <p class="kicker">Hello, I’m</p>
    <h1>{site.name}</h1>
    <p class="role">{site.role}</p>
    <p class="tagline">{site.tagline}</p>
    <div class="cta">
      <a class="btn btn-primary" href="#projects">View my work</a>
      <a class="btn btn-outline" href={`${base}${site.resumeFile}`} download>Download resume</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: 6.5rem 5rem;
    background:
      radial-gradient(60rem 30rem at 80% -10%, var(--accent-soft), transparent);
  }

  .kicker {
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .role {
    font-size: clamp(1.15rem, 3vw, 1.5rem);
    color: var(--text-muted);
    font-weight: 600;
    margin-top: 0.35rem;
  }

  .tagline {
    max-width: 38rem;
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
</style>

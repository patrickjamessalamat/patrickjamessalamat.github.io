---
import { skills } from '../data/skills';
---

<section id="skills">
  <h2 class="section-heading">Skills</h2>
  <div class="box">
    <div class="box-body groups">
      {skills.map((group) => (
        <div class="group">
          <h3>{group.category}</h3>
          <ul>
            {group.items.map((item) => (
              <li class="topic">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .groups {
    display: grid;
    gap: 16px;
  }

  .group h3 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .group ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
</style>

---
import { languageColors, type Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const dotColor = languageColors[project.language] ?? '#8b949e';
const titleUrl = project.repoUrl ?? project.demoUrl;
const visibility = project.visibility ?? 'Public';
const itemCount = project.items?.length ?? 0;
---

<article class="box flex flex-col gap-2 p-4">
  <div class="flex flex-wrap items-center gap-2 text-sm">
    <svg class="shrink-0 fill-muted" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M3 2.5A1.5 1.5 0 0 1 4.5 1h8a.5.5 0 0 1 .5.5v11a.5.5 0 0 1-.5.5H5v1h7.5a.5.5 0 0 1 0 1h-8A1.5 1.5 0 0 1 3 13.5Zm1.5-.5a.5.5 0 0 0-.5.5v10.6c.2-.1.3-.1.5-.1H12V2Z"/>
    </svg>
    {titleUrl ? (
      <a class="font-semibold" href={titleUrl} target="_blank" rel="noopener noreferrer">{project.title}</a>
    ) : (
      <span class="font-semibold">{project.title}</span>
    )}
    <span class="rounded-full border border-line px-[7px] text-xs leading-[18px] text-muted">{visibility}</span>
    {itemCount > 0 && (
      <span class="rounded-full border border-line px-[7px] text-xs leading-[18px] text-muted">
        {itemCount} {itemCount === 1 ? 'project' : 'projects'}
      </span>
    )}
  </div>
  <div class="flex flex-1 flex-col gap-2">
    {project.description?.map((paragraph) => (
      <p class="text-xs text-muted" set:html={paragraph} />
    ))}
    {/* Grouped entries list only their sub-project names here; the Projects page carries the detail. */}
    {project.items && project.items.length > 0 && (
      <ul class="grid gap-1.5 border-l border-line pl-4 text-xs text-muted">
        {project.items.map((item) => (
          <li class="relative before:absolute before:-left-[19px] before:top-[5px] before:h-1.5 before:w-1.5 before:rounded-full before:border-2 before:border-canvas before:bg-muted before:content-['']">
            {item.repoUrl ?? item.demoUrl ? (
              <a href={item.repoUrl ?? item.demoUrl} target="_blank" rel="noopener noreferrer">{item.name}</a>
            ) : (
              item.name
            )}
          </li>
        ))}
      </ul>
    )}
  </div>
  <ul class="flex flex-wrap gap-1">
    {project.tags.map((tag) => (
      <li class="topic">{tag}</li>
    ))}
  </ul>
  <div class="flex items-center gap-4 text-xs text-muted">
    <span class="inline-flex items-center gap-[5px]">
      <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background:${dotColor}`} aria-hidden="true"></span>
      {project.language}
    </span>
    {project.repoUrl && (
      <a class="font-medium" href={project.repoUrl} target="_blank" rel="noopener noreferrer">Source</a>
    )}
  </div>
</article>

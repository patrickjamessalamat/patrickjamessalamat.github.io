---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const languageColors: Record<string, string> = {
  TypeScript: '#3178c6',
  JavaScript: '#f1e05a',
  Python: '#3572a5',
  Astro: '#ff5a03',
  HTML: '#e34c26',
  CSS: '#663399',
  Go: '#00add8',
  Rust: '#dea584',
};

const dotColor = languageColors[project.language] ?? '#8b949e';
const titleUrl = project.repoUrl ?? project.demoUrl;
---

<article class="box flex flex-col gap-2 p-4">
  <div class="flex items-center gap-2 text-sm">
    <svg class="shrink-0 fill-muted" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M3 2.5A1.5 1.5 0 0 1 4.5 1h8a.5.5 0 0 1 .5.5v11a.5.5 0 0 1-.5.5H5v1h7.5a.5.5 0 0 1 0 1h-8A1.5 1.5 0 0 1 3 13.5Zm1.5-.5a.5.5 0 0 0-.5.5v10.6c.2-.1.3-.1.5-.1H12V2Z"/>
    </svg>
    {titleUrl ? (
      <a class="font-semibold" href={titleUrl} target="_blank" rel="noopener noreferrer">{project.title}</a>
    ) : (
      <span class="font-semibold">{project.title}</span>
    )}
    <span class="rounded-full border border-line px-[7px] text-xs leading-[18px] text-muted">Public</span>
  </div>
  <p class="flex-1 text-xs text-muted">{project.description}</p>
  <ul class="flex flex-wrap gap-1">
    {project.tags.map((tag) => (
      <li class="topic">{tag}</li>
    ))}
  </ul>
  <div class="flex items-center gap-4 text-xs text-muted">
    <span class="inline-flex items-center gap-[5px]">
      <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background:${dotColor}`} aria-hidden="true"></span>
      {project.language}
    </span>
    {project.demoUrl && (
      <a class="font-medium" href={project.demoUrl} target="_blank" rel="noopener noreferrer">Live demo</a>
    )}
    {project.repoUrl && (
      <a class="font-medium" href={project.repoUrl} target="_blank" rel="noopener noreferrer">Source</a>
    )}
  </div>
</article>

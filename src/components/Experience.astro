---
import { experience } from '../data/experience';

const work = experience.filter((entry) => entry.kind === 'work');
const education = experience.filter((entry) => entry.kind === 'education');
---

<section id="experience">
  <div class="container">
    <h2 class="section-title">Experience</h2>
    <p class="section-lead">Where I’ve worked and studied.</p>
    <div class="columns">
      <div>
        <h3 class="column-title">Work</h3>
        <ol class="timeline">
          {work.map((entry) => (
            <li>
              <p class="period">{entry.period}</p>
              <h4>{entry.title}</h4>
              <p class="org">{entry.organization}</p>
              <p class="desc">{entry.description}</p>
            </li>
          ))}
        </ol>
      </div>
      <div>
        <h3 class="column-title">Education</h3>
        <ol class="timeline">
          {education.map((entry) => (
            <li>
              <p class="period">{entry.period}</p>
              <h4>{entry.title}</h4>
              <p class="org">{entry.organization}</p>
              <p class="desc">{entry.description}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  .columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  @media (max-width: 720px) {
    .columns {
      grid-template-columns: 1fr;
    }
  }

  .column-title {
    font-size: 1.05rem;
    margin-bottom: 1.25rem;
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .timeline {
    list-style: none;
    border-left: 2px solid var(--border);
    display: grid;
    gap: 1.75rem;
  }

  .timeline li {
    position: relative;
    padding-left: 1.5rem;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -0.375rem;
    top: 0.4rem;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--accent);
  }

  .period {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  h4 {
    font-size: 1.05rem;
    margin-top: 0.15rem;
  }

  .org {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.92rem;
  }

  .desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 0.35rem;
  }
</style>

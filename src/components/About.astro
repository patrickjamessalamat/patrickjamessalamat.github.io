---
import { site } from '../data/site';
---

<section id="about">
  <div class="container">
    <h2 class="section-title">About me</h2>
    <div class="about-body">
      {site.bio.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</section>

<style>
  .about-body {
    max-width: 44rem;
    display: grid;
    gap: 1rem;
    color: var(--text-muted);
    font-size: 1.03rem;
  }
</style>

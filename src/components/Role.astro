---
import type { Role } from '../data/experience';

interface Props {
  role: Role;
  // When set (single-role companies), the company line is shown under the title.
  organization?: string;
  location?: string;
}

const { role, organization, location } = Astro.props;
---

<div>
  <h3 class="text-lg font-semibold leading-snug">{role.title}</h3>
  {organization && (
    <p class="text-sm">
      <span class="font-medium text-accent">{organization}</span>
      {location && <span class="text-muted"> · {location}</span>}
    </p>
  )}
  {role.employmentType && <p class="text-sm text-muted">{role.employmentType}</p>}
  <p class="font-mono text-xs text-muted">
    {role.period}{role.duration && ` · ${role.duration}`}
  </p>
  {role.workMode && <p class="text-sm text-muted">{role.workMode}</p>}
  {role.description && role.description.length > 0 && (
    <div class="mt-3 grid gap-2">
      {role.description.map((paragraph) => (
        <p class="text-sm text-muted">{paragraph}</p>
      ))}
    </div>
  )}
  {role.skills && role.skills.length > 0 && (
    <ul class="mt-3 flex flex-wrap gap-2">
      {role.skills.map((skill) => (
        <li class="topic">{skill}</li>
      ))}
    </ul>
  )}
</div>

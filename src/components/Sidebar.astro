---
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
const initials = site.name
  .split(' ')
  .map((part) => part.charAt(0))
  .slice(0, 2)
  .join('');
---

<aside class="sidebar">
  <div class="avatar" aria-hidden="true">{initials}</div>
  <h1 class="name">{site.name}</h1>
  <p class="handle">{site.handle} · {site.role}</p>
  <p class="bio">{site.tagline}</p>
  <a class="btn btn-primary btn-block" href={`${base}${site.resumeFile}`} download>
    Download resume
  </a>
  <ul class="details">
    <li>
      <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M8 1a5 5 0 0 0-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 0 0-5-5Zm0 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"/>
      </svg>
      {site.location}
    </li>
    <li>
      <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M1 4.5A1.5 1.5 0 0 1 2.5 3h11A1.5 1.5 0 0 1 15 4.5v7a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 11.5Zm1.7-.2 5.3 4 5.3-4H2.7ZM14 5.8 8.6 9.9a1 1 0 0 1-1.2 0L2 5.8v5.7c0 .3.2.5.5.5h11c.3 0 .5-.2.5-.5Z"/>
      </svg>
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </li>
    {site.socials.map((social) => (
      <li>
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M7.8 8.9a3 3 0 0 0 4.2 0l2.2-2.2a3 3 0 1 0-4.3-4.2L8.7 3.7l1 1 1.2-1.2a1.6 1.6 0 0 1 2.3 2.3L11 8a1.6 1.6 0 0 1-2.3 0ZM8.2 7.1a3 3 0 0 0-4.2 0L1.8 9.3a3 3 0 1 0 4.3 4.2l1.2-1.2-1-1-1.2 1.2a1.6 1.6 0 0 1-2.3-2.3L5 8a1.6 1.6 0 0 1 2.3 0Z"/>
        </svg>
        <a href={social.url} target="_blank" rel="noopener noreferrer">{social.label}</a>
      </li>
    ))}
  </ul>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .avatar {
    width: min(260px, 60vw);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: linear-gradient(135deg, #1f883d, #0969da);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(3rem, 12vw, 5rem);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .name {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.25;
  }

  .handle {
    font-size: 18px;
    font-weight: 300;
    color: var(--fg-muted);
    margin-top: -12px;
  }

  .bio {
    font-size: 16px;
  }

  .details {
    list-style: none;
    display: grid;
    gap: 8px;
    font-size: 14px;
  }

  .details li {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--fg-muted);
  }

  .details svg {
    flex-shrink: 0;
    fill: var(--fg-muted);
  }
</style>

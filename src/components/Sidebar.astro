---
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;

// Brand icons keyed by social label; falls back to a generic link glyph.
const socialIcons: Record<string, { viewBox: string; path: string }> = {
  GitHub: {
    viewBox: '0 0 16 16',
    path: 'M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z',
  },
  LinkedIn: {
    viewBox: '0 0 24 24',
    path: 'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z',
  },
};

const fallbackIcon = {
  viewBox: '0 0 16 16',
  path: 'M7.8 8.9a3 3 0 0 0 4.2 0l2.2-2.2a3 3 0 1 0-4.3-4.2L8.7 3.7l1 1 1.2-1.2a1.6 1.6 0 0 1 2.3 2.3L11 8a1.6 1.6 0 0 1-2.3 0ZM8.2 7.1a3 3 0 0 0-4.2 0L1.8 9.3a3 3 0 1 0 4.3 4.2l1.2-1.2-1-1-1.2 1.2a1.6 1.6 0 0 1-2.3-2.3L5 8a1.6 1.6 0 0 1 2.3 0Z',
};
---

<aside class="flex flex-col gap-4">
  <div class="flex items-center gap-4 md:flex-col md:items-stretch">
    <img
      class="aspect-square w-20 shrink-0 rounded-full border border-line object-cover sm:w-24 md:w-full"
      src={`${base}${site.avatar}`}
      alt={`Photo of ${site.name}`}
    />
    <div>
      <h1 class="text-xl font-semibold leading-tight sm:text-2xl">{site.name}</h1>
      <p class="text-base font-light text-muted sm:text-lg">{site.handle} · {site.role}</p>
    </div>
  </div>
  <p class="text-base">{site.tagline}</p>
  <a
    class="btn btn-primary flex w-full"
    href={`${base}${site.resumeFile}`}
    download={`${site.name}.pdf`}
    data-analytics="resume_download"
  >
    Download resume
  </a>
  <ul class="grid gap-2 text-sm">
    <li class="flex items-center gap-2 text-muted">
      <svg class="shrink-0 fill-muted" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M8 1a5 5 0 0 0-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 0 0-5-5Zm0 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"/>
      </svg>
      {site.location}
    </li>
    <li class="flex items-center gap-2 text-muted">
      <svg class="shrink-0 fill-muted" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M1 4.5A1.5 1.5 0 0 1 2.5 3h11A1.5 1.5 0 0 1 15 4.5v7a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 11.5Zm1.7-.2 5.3 4 5.3-4H2.7ZM14 5.8 8.6 9.9a1 1 0 0 1-1.2 0L2 5.8v5.7c0 .3.2.5.5.5h11c.3 0 .5-.2.5-.5Z"/>
      </svg>
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </li>
    {site.socials.map((social) => {
      const icon = socialIcons[social.label] ?? fallbackIcon;
      return (
        <li class="flex items-center gap-2 text-muted">
          <svg class="shrink-0 fill-muted" width="16" height="16" viewBox={icon.viewBox} aria-hidden="true">
            <path d={icon.path} />
          </svg>
          <a href={social.url} target="_blank" rel="noopener noreferrer">{social.label}</a>
        </li>
      );
    })}
  </ul>
</aside>

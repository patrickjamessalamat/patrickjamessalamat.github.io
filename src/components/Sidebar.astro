---
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
const initials = site.name
  .split(' ')
  .map((part) => part.charAt(0))
  .slice(0, 2)
  .join('');
---

<aside class="flex flex-col gap-4">
  <div
    class="flex aspect-square w-[min(260px,60vw)] items-center justify-center rounded-full border border-line bg-linear-to-br from-btn-green to-accent text-[clamp(3rem,12vw,5rem)] font-bold tracking-wide text-white"
    aria-hidden="true"
  >
    {initials}
  </div>
  <div>
    <h1 class="text-2xl font-semibold leading-tight">{site.name}</h1>
    <p class="text-lg font-light text-muted">{site.handle} · {site.role}</p>
  </div>
  <p class="text-base">{site.tagline}</p>
  <a class="btn btn-primary flex w-full" href={`${base}${site.resumeFile}`} download>
    Download resume
  </a>
  <ul class="grid gap-2 text-sm">
    <li class="flex items-center gap-2 text-muted">
      <svg class="shrink-0 fill-muted" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M8 1a5 5 0 0 0-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 0 0-5-5Zm0 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"/>
      </svg>
      {site.location}
    </li>
    <li class="flex items-center gap-2 text-muted">
      <svg class="shrink-0 fill-muted" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M1 4.5A1.5 1.5 0 0 1 2.5 3h11A1.5 1.5 0 0 1 15 4.5v7a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 11.5Zm1.7-.2 5.3 4 5.3-4H2.7ZM14 5.8 8.6 9.9a1 1 0 0 1-1.2 0L2 5.8v5.7c0 .3.2.5.5.5h11c.3 0 .5-.2.5-.5Z"/>
      </svg>
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </li>
    {site.socials.map((social) => (
      <li class="flex items-center gap-2 text-muted">
        <svg class="shrink-0 fill-muted" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M7.8 8.9a3 3 0 0 0 4.2 0l2.2-2.2a3 3 0 1 0-4.3-4.2L8.7 3.7l1 1 1.2-1.2a1.6 1.6 0 0 1 2.3 2.3L11 8a1.6 1.6 0 0 1-2.3 0ZM8.2 7.1a3 3 0 0 0-4.2 0L1.8 9.3a3 3 0 1 0 4.3 4.2l1.2-1.2-1-1-1.2 1.2a1.6 1.6 0 0 1-2.3-2.3L5 8a1.6 1.6 0 0 1 2.3 0Z"/>
        </svg>
        <a href={social.url} target="_blank" rel="noopener noreferrer">{social.label}</a>
      </li>
    ))}
  </ul>
</aside>

---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { site } from '../data/site';
import { projectCount } from '../data/projects';
import { credentials } from '../data/certifications';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} (${site.handle})`,
  description = site.tagline,
} = Astro.props;

// 16x16 octicon-style paths for the tab icons
const icons = {
  book: 'M2 2.5A1.5 1.5 0 0 1 3.5 1H7a2 2 0 0 1 1 .27A2 2 0 0 1 9 1h3.5A1.5 1.5 0 0 1 14 2.5v9a1.5 1.5 0 0 1-1.5 1.5h-3a1 1 0 0 0-.8.4l-.3.4a.5.5 0 0 1-.8 0l-.3-.4a1 1 0 0 0-.8-.4h-3A1.5 1.5 0 0 1 2 11.5Zm6.5.5v9.1c.32-.06.66-.1 1-.1h3a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5H9a.5.5 0 0 0-.5.5Zm-1 9.1V3a.5.5 0 0 0-.5-.5H3.5a.5.5 0 0 0-.5.5v8.5c0 .28.22.5.5.5h3c.34 0 .68.04 1 .1Z',
  table: 'M2.5 2h11A1.5 1.5 0 0 1 15 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 12.5v-9A1.5 1.5 0 0 1 2.5 2ZM2 6v6.5c0 .28.22.5.5.5H6V6Zm5.5 7h2V6h-2Zm3.5 0h2.5a.5.5 0 0 0 .5-.5V6H11ZM14 4.5v-1a.5.5 0 0 0-.5-.5h-11a.5.5 0 0 0-.5.5v1Z',
  zap: 'M9.8.7a.5.5 0 0 1 .35.6L9.1 6h3.4a.5.5 0 0 1 .4.8l-6.6 8.4a.5.5 0 0 1-.88-.44L6.9 10H3.5a.5.5 0 0 1-.4-.8L9.2.9a.5.5 0 0 1 .6-.2Z',
  briefcase: 'M6 2.5A1.5 1.5 0 0 1 7.5 1h1A1.5 1.5 0 0 1 10 2.5V3h3.5A1.5 1.5 0 0 1 15 4.5v8a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 12.5v-8A1.5 1.5 0 0 1 2.5 3H6ZM7 3h2v-.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5Zm-4.5 1.5a.5.5 0 0 0-.5.5V7h12V5a.5.5 0 0 0-.5-.5ZM14 8.5H2v4c0 .28.22.5.5.5h11a.5.5 0 0 0 .5-.5Z',
  mail: 'M1 4.5A1.5 1.5 0 0 1 2.5 3h11A1.5 1.5 0 0 1 15 4.5v7a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 11.5Zm1.7-.2 5.3 4 5.3-4H2.7ZM14 5.8 8.6 9.9a1 1 0 0 1-1.2 0L2 5.8v5.7c0 .3.2.5.5.5h11c.3 0 .5-.2.5-.5Z',
  shield: 'M8 .27l6 2.4v4.6c0 3.6-2.5 6.9-6 7.9-3.5-1-6-4.3-6-7.9v-4.6L8 .27Zm0 1.6L3.5 3.7v3.57c0 2.9 1.9 5.6 4.5 6.5 2.6-.9 4.5-3.6 4.5-6.5V3.7L8 1.87Zm2.8 3.7 1 1-4.2 4.2-2.4-2.4 1-1 1.4 1.4 3.2-3.2Z',
};

const base = import.meta.env.BASE_URL;

// Monogram shown in the header instead of the avatar: "Patrick James Salamat" → PJS
const monogram = site.name
  .split(/\s+/)
  .map((word) => word[0])
  .join('')
  .toUpperCase();


// Every tab is its own page; the current one is derived from the URL.
const path = Astro.url.pathname.replace(/\/$/, '');
const home = base.replace(/\/$/, '');

const tabs = [
  { href: base, label: 'Overview', icon: icons.book, current: path === home },
  {
    href: `${base}projects/`,
    label: 'Projects',
    icon: icons.table,
    count: projectCount,
    current: path.endsWith('/projects'),
  },
  { href: `${base}stacks/`, label: 'Stacks', icon: icons.zap, current: path.endsWith('/stacks') },
  { href: `${base}experience/`, label: 'Experience', icon: icons.briefcase, current: path.endsWith('/experience') },
  {
    href: `${base}certifications/`,
    label: 'Certifications',
    icon: icons.shield,
    count: credentials.length,
    current: path.endsWith('/certifications'),
  },
  { href: `${base}contact/`, label: 'Contact', icon: icons.mail, current: path.endsWith('/contact') },
];

const currentTab = tabs.find((tab) => tab.current) ?? tabs[0];

// Only the build that runs in GitHub Actions is a real deployment. `astro dev`
// and a local `astro build` both stay out of Google Analytics and out of search
// results — PROD alone is not enough, since a local build sets it too.
const isDeployed = import.meta.env.PROD && process.env.GITHUB_ACTIONS === 'true';
const analyticsId = isDeployed ? site.analyticsId : '';

// Absolute URLs — crawlers and social scrapers reject relative ones.
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;
const ogImage = Astro.site
  ? new URL(`${base}${site.avatar}`, Astro.site).href
  : `${base}${site.avatar}`;

// Structured data so search engines can render a knowledge-panel style result.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: Astro.site?.href ?? canonical,
  image: ogImage,
  jobTitle: site.role,
  email: `mailto:${site.email}`,
  telephone: site.phone,
  address: { '@type': 'PostalAddress', addressCountry: site.location },
  sameAs: site.socials.map((social) => social.url),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    {site.googleSiteVerification && (
      <meta name="google-site-verification" content={site.googleSiteVerification} />
    )}
    <meta name="robots" content={isDeployed ? 'index, follow' : 'noindex, nofollow'} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`Photo of ${site.name}`} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href={`${base}sitemap.xml`} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
    <script is:inline>
      // Apply the stored theme before first paint to avoid a flash
      const storedTheme = localStorage.getItem('theme');
      if (storedTheme === 'light' || storedTheme === 'dark') {
        document.documentElement.dataset.theme = storedTheme;
      }
    </script>
    {analyticsId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${analyticsId}`}></script>
        <script is:inline define:vars={{ gaId: analyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());

          // Let gtag send the first page_view itself. That hit must not depend
          // on astro:page-load reaching us, or a single failure there means GA
          // records nothing at all.
          gtag('config', gaId);

          if (!window.__gaInit) {
            window.__gaInit = true;

            // The ClientRouter navigates without a reload, so gtag never sees
            // later pages. Send those manually — skipping the first event,
            // which gtag('config', …) has already reported.
            let isFirstLoad = true;
            document.addEventListener('astro:page-load', () => {
              if (isFirstLoad) {
                isFirstLoad = false;
                return;
              }
              gtag('event', 'page_view', {
                page_title: document.title,
                page_location: location.href,
                page_path: location.pathname,
              });
            });

            // Any <a data-analytics="event_name"> reports a custom event.
            // Delegated from document so it survives client-side navigation.
            document.addEventListener('click', (event) => {
              const link = event.target.closest('a[data-analytics]');
              if (!link) return;
              gtag('event', link.dataset.analytics, {
                link_text: link.textContent.trim(),
                link_url: link.href,
                page_path: location.pathname,
              });
            });
          }
        </script>
      </>
    )}
    <ClientRouter />
  </head>
  <!-- Column layout so the footer sits at the viewport bottom on short pages -->
  <body class="flex min-h-screen flex-col">
    <!-- GitHub-style top progress bar for client-side navigation -->
    <div id="page-loader" transition:persist="page-loader" aria-hidden="true"></div>
    <header class="sticky top-0 z-10">
      <!-- Top bar: always GitHub's dark header color, full width -->
      <div class="flex items-center justify-between bg-[#010409] px-4 py-3">
        <a
          href={base}
          class="inline-flex min-w-0 items-center gap-2 text-sm font-semibold text-white hover:no-underline hover:opacity-80 sm:gap-3"
        >
          <span
            class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white text-[12px] font-black leading-none tracking-tight text-black"
            aria-hidden="true"
          >
            {monogram}
          </span>
          <span class="truncate">{site.handle}</span>
        </a>
        <div class="flex shrink-0 items-center gap-3">
          <span class="hidden font-mono text-xs text-[#9198a1] sm:inline">portfolio</span>
          <button
            id="theme-toggle"
            type="button"
            class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-md border border-[#30363d] text-[#9198a1] hover:text-white"
            aria-label="Toggle color theme"
          >
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M9.5 1.3a6.9 6.9 0 1 0 5.2 9.9.5.5 0 0 0-.6-.7A5.4 5.4 0 0 1 7 3.6a5.4 5.4 0 0 1 3-1.6.5.5 0 0 0 0-.9 6.9 6.9 0 0 0-.5.2Z"/>
            </svg>
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 10.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Zm0 1.5a4 4 0 1 1 0-8 4 4 0 0 1 0 8ZM8 0a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1A.75.75 0 0 1 8 0Zm0 13.5a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1A.75.75 0 0 1 8 13.5ZM16 8a.75.75 0 0 1-.75.75h-1a.75.75 0 0 1 0-1.5h1A.75.75 0 0 1 16 8ZM2.5 8a.75.75 0 0 1-.75.75h-1a.75.75 0 0 1 0-1.5h1A.75.75 0 0 1 2.5 8Zm10.7-5.2a.75.75 0 0 1 0 1.06l-.7.7a.75.75 0 1 1-1.06-1.06l.7-.7a.75.75 0 0 1 1.06 0ZM4.56 11.44a.75.75 0 0 1 0 1.06l-.7.7A.75.75 0 0 1 2.8 12.14l.7-.7a.75.75 0 0 1 1.06 0Zm8.64 1.76a.75.75 0 0 1-1.06 0l-.7-.7a.75.75 0 0 1 1.06-1.06l.7.7a.75.75 0 0 1 0 1.06ZM4.56 4.56a.75.75 0 0 1-1.06 0l-.7-.7A.75.75 0 0 1 3.86 2.8l.7.7a.75.75 0 0 1 0 1.06Z"/>
            </svg>
          </button>
        </div>
      </div>
      <!-- Tab row: inline tabs on ≥sm, hamburger-toggled menu on mobile -->
      <nav class="border-b border-[#30363d] bg-[#010409]" aria-label="Profile sections">
        <!-- Mobile: hamburger toggle showing the current section -->
        <button
          id="nav-toggle"
          type="button"
          class="flex w-full items-center justify-between px-4 py-3 text-sm text-[#e6edf3] sm:hidden"
          aria-expanded="false"
          aria-controls="nav-menu"
        >
          <span class="flex items-center gap-2 font-semibold">
            <svg class="shrink-0 fill-[#9198a1]" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d={currentTab.icon} />
            </svg>
            {currentTab.label}
          </span>
          <svg class="icon-menu shrink-0 fill-[#9198a1]" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M1 3.75A.75.75 0 0 1 1.75 3h12.5a.75.75 0 0 1 0 1.5H1.75A.75.75 0 0 1 1 3.75Zm0 4A.75.75 0 0 1 1.75 7h12.5a.75.75 0 0 1 0 1.5H1.75A.75.75 0 0 1 1 7.75ZM1.75 11h12.5a.75.75 0 0 1 0 1.5H1.75a.75.75 0 0 1 0-1.5Z"/>
          </svg>
          <svg class="icon-close hidden shrink-0 fill-[#9198a1]" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M3.72 3.72a.75.75 0 0 1 1.06 0L8 6.94l3.22-3.22a.75.75 0 1 1 1.06 1.06L9.06 8l3.22 3.22a.75.75 0 1 1-1.06 1.06L8 9.06l-3.22 3.22a.75.75 0 0 1-1.06-1.06L6.94 8 3.72 4.78a.75.75 0 0 1 0-1.06Z"/>
          </svg>
        </button>
        <ul
          id="nav-menu"
          class="hidden flex-col pb-2 sm:flex sm:flex-row sm:gap-2 sm:overflow-x-auto sm:px-4 sm:pb-0"
        >
          {tabs.map((tab) => (
            <li class="sm:shrink-0">
              <a
                href={tab.href}
                class="flex w-full items-center gap-2 whitespace-nowrap border-transparent px-4 py-2.5 text-sm leading-[23px] text-[#e6edf3] hover:bg-white/5 hover:no-underline aria-[current=page]:font-semibold sm:w-auto sm:border-b-2 sm:px-3 sm:pb-2.5 sm:pt-2 sm:hover:border-[#30363d] sm:hover:bg-transparent sm:aria-[current=page]:border-[#f78166]"
                aria-current={tab.current ? 'page' : undefined}
              >
                <svg class="shrink-0 fill-[#9198a1]" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                  <path d={tab.icon} />
                </svg>
                {tab.label}
                {tab.count !== undefined && (
                  <span class="rounded-full bg-white/15 px-2 text-xs font-medium leading-[18px]">{tab.count}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="overview" class="flex-1">
      <slot />
    </main>

    <footer class="mt-10 border-t border-line py-6">
      <div class="mx-auto max-w-[1216px] px-4 text-center text-xs text-muted">
        <p>© {new Date().getFullYear()} {site.name}</p>
      </div>
    </footer>

    <script>
      // Runs on initial load AND after every client-side navigation, since
      // the ClientRouter swaps the body and all element listeners with it.
      const initPage = () => {
        // Theme toggle: flips between light and dark, starting from the
        // effective theme (stored preference or system setting)
        document.querySelector('#theme-toggle')?.addEventListener('click', (event) => {
          const root = document.documentElement;
          const systemDark = matchMedia('(prefers-color-scheme: dark)').matches;
          const current = root.dataset.theme ?? (systemDark ? 'dark' : 'light');
          const next = current === 'dark' ? 'light' : 'dark';

          const apply = () => {
            root.dataset.theme = next;
            localStorage.setItem('theme', next);
          };

          const doc = document as Document & {
            startViewTransition?: (cb: () => void) => {
              ready: Promise<void>;
              finished: Promise<void>;
            };
          };
          const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

          // Unsupported browsers and reduced-motion users just get the flip.
          if (!doc.startViewTransition || reduceMotion) {
            apply();
            return;
          }

          // Circle grows from the button's centre to whichever page corner is
          // furthest away, so it always covers the viewport.
          const button = event.currentTarget as HTMLElement;
          const box = button.getBoundingClientRect();
          const x = box.left + box.width / 2;
          const y = box.top + box.height / 2;
          const radius = Math.hypot(
            Math.max(x, innerWidth - x),
            Math.max(y, innerHeight - y),
          );

          root.dataset.themeSwitch = '';
          const transition = doc.startViewTransition(apply);

          transition.ready.then(() => {
            root.animate(
              {
                clipPath: [
                  `circle(0px at ${x}px ${y}px)`,
                  `circle(${radius}px at ${x}px ${y}px)`,
                ],
              },
              {
                duration: 450,
                easing: 'ease-in-out',
                pseudoElement: '::view-transition-new(root)',
              },
            );
          });

          // Drop the flag so page navigations keep their own transition.
          transition.finished.finally(() => {
            delete root.dataset.themeSwitch;
          });
        });

        // Mobile nav hamburger: toggle the collapsed section menu
        const navToggle = document.querySelector('#nav-toggle');
        const navMenu = document.querySelector('#nav-menu');
        navToggle?.addEventListener('click', () => {
          const isOpen = navMenu?.classList.toggle('hidden') === false;
          navToggle.setAttribute('aria-expanded', String(isOpen));
          navToggle.querySelector('.icon-menu')?.classList.toggle('hidden', isOpen);
          navToggle.querySelector('.icon-close')?.classList.toggle('hidden', !isOpen);
        });
      };
      document.addEventListener('astro:page-load', initPage);

      // The router swaps <html> attributes on navigation, which would drop a
      // manually chosen theme — re-apply it right after each swap.
      document.addEventListener('astro:after-swap', () => {
        const stored = localStorage.getItem('theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.dataset.theme = stored;
        }
      });

      // GitHub-style top progress bar: crawl while the next page is being
      // fetched, then snap to 100% and fade out when it's ready.
      const loader = document.getElementById('page-loader');
      document.addEventListener('astro:before-preparation', () => {
        if (!loader) return;
        loader.dataset.loading = 'true';
        loader.style.transition = 'none';
        loader.style.width = '0';
        loader.style.opacity = '1';
        void loader.offsetWidth; // flush so the crawl animates from 0
        loader.style.transition = 'width 4s cubic-bezier(0.05, 0.6, 0.1, 1)';
        loader.style.width = '82%';
      });
      document.addEventListener('astro:page-load', () => {
        if (!loader || loader.dataset.loading !== 'true') return;
        delete loader.dataset.loading;
        loader.style.transition = 'width 0.2s ease, opacity 0.3s ease 0.25s';
        loader.style.width = '100%';
        loader.style.opacity = '0';
      });
    </script>
  </body>
</html>

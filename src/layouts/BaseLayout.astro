---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} (${site.handle})`,
  description = site.tagline,
} = Astro.props;

const tabs = [
  { href: '#overview', label: 'Overview' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
];

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={Astro.site ? new URL(base, Astro.site).href : base} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={base} class="brand">
          <span class="brand-avatar" aria-hidden="true">{site.name.charAt(0)}</span>
          <span class="brand-name">{site.handle}</span>
        </a>
        <span class="header-note">portfolio</span>
      </div>
      <nav class="container tab-nav" aria-label="Profile sections">
        {tabs.map((tab, index) => (
          <a href={tab.href} class="tab" data-tab aria-current={index === 0 ? 'page' : undefined}>
            {tab.label}
          </a>
        ))}
      </nav>
    </header>

    <main id="overview">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>© {new Date().getFullYear()} {site.name}</p>
        <p>Built with Astro · Inspired by the GitHub profile layout</p>
      </div>
    </footer>

    <script>
      // Highlight the tab of the section currently in view
      const tabs = [...document.querySelectorAll<HTMLAnchorElement>('[data-tab]')];
      const sections = tabs
        .map((tab) => document.querySelector(tab.hash))
        .filter((section): section is Element => section !== null);

      const activate = (hash: string) => {
        for (const tab of tabs) {
          if (tab.hash === hash) tab.setAttribute('aria-current', 'page');
          else tab.removeAttribute('aria-current');
        }
      };

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) activate(`#${entry.target.id}`);
          }
        },
        { rootMargin: '-40% 0px -55% 0px' }
      );
      sections.forEach((section) => observer.observe(section));
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--canvas-subtle);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 12px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--fg);
    font-weight: 600;
    font-size: 14px;
  }

  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .brand-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1f883d, #0969da);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
  }

  .header-note {
    font-size: 12px;
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }

  .tab-nav {
    display: flex;
    gap: 8px;
    overflow-x: auto;
  }

  .tab {
    padding: 8px 12px 10px;
    color: var(--fg);
    font-size: 14px;
    line-height: 23px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  .tab:hover {
    text-decoration: none;
    border-bottom-color: var(--border);
  }

  .tab[aria-current='page'] {
    font-weight: 600;
    border-bottom-color: var(--tab-active);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 40px;
    padding-block: 24px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--fg-muted);
    font-size: 12px;
  }
</style>

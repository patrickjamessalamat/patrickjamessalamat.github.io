---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { site } from '../data/site';
import { projects } from '../data/projects';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} (${site.handle})`,
  description = site.tagline,
} = Astro.props;

// 16x16 octicon-style paths for the tab icons
const icons = {
  book: 'M2 2.5A1.5 1.5 0 0 1 3.5 1H7a2 2 0 0 1 1 .27A2 2 0 0 1 9 1h3.5A1.5 1.5 0 0 1 14 2.5v9a1.5 1.5 0 0 1-1.5 1.5h-3a1 1 0 0 0-.8.4l-.3.4a.5.5 0 0 1-.8 0l-.3-.4a1 1 0 0 0-.8-.4h-3A1.5 1.5 0 0 1 2 11.5Zm6.5.5v9.1c.32-.06.66-.1 1-.1h3a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5H9a.5.5 0 0 0-.5.5Zm-1 9.1V3a.5.5 0 0 0-.5-.5H3.5a.5.5 0 0 0-.5.5v8.5c0 .28.22.5.5.5h3c.34 0 .68.04 1 .1Z',
  table: 'M2.5 2h11A1.5 1.5 0 0 1 15 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 12.5v-9A1.5 1.5 0 0 1 2.5 2ZM2 6v6.5c0 .28.22.5.5.5H6V6Zm5.5 7h2V6h-2Zm3.5 0h2.5a.5.5 0 0 0 .5-.5V6H11ZM14 4.5v-1a.5.5 0 0 0-.5-.5h-11a.5.5 0 0 0-.5.5v1Z',
  zap: 'M9.8.7a.5.5 0 0 1 .35.6L9.1 6h3.4a.5.5 0 0 1 .4.8l-6.6 8.4a.5.5 0 0 1-.88-.44L6.9 10H3.5a.5.5 0 0 1-.4-.8L9.2.9a.5.5 0 0 1 .6-.2Z',
  briefcase: 'M6 2.5A1.5 1.5 0 0 1 7.5 1h1A1.5 1.5 0 0 1 10 2.5V3h3.5A1.5 1.5 0 0 1 15 4.5v8a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 12.5v-8A1.5 1.5 0 0 1 2.5 3H6ZM7 3h2v-.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5Zm-4.5 1.5a.5.5 0 0 0-.5.5V7h12V5a.5.5 0 0 0-.5-.5ZM14 8.5H2v4c0 .28.22.5.5.5h11a.5.5 0 0 0 .5-.5Z',
  mail: 'M1 4.5A1.5 1.5 0 0 1 2.5 3h11A1.5 1.5 0 0 1 15 4.5v7a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 11.5Zm1.7-.2 5.3 4 5.3-4H2.7ZM14 5.8 8.6 9.9a1 1 0 0 1-1.2 0L2 5.8v5.7c0 .3.2.5.5.5h11c.3 0 .5-.2.5-.5Z',
};

const base = import.meta.env.BASE_URL;

// Every tab is its own page; the current one is derived from the URL.
const path = Astro.url.pathname.replace(/\/$/, '');
const home = base.replace(/\/$/, '');

const tabs = [
  { href: base, label: 'Overview', icon: icons.book, current: path === home },
  {
    href: `${base}projects/`,
    label: 'Projects',
    icon: icons.table,
    count: projects.length,
    current: path.endsWith('/projects'),
  },
  { href: `${base}stacks/`, label: 'Stacks', icon: icons.zap, current: path.endsWith('/stacks') },
  { href: `${base}experience/`, label: 'Experience', icon: icons.briefcase, current: path.endsWith('/experience') },
  { href: `${base}contact/`, label: 'Contact', icon: icons.mail, current: path.endsWith('/contact') },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname} />
    <script is:inline>
      // Apply the stored theme before first paint to avoid a flash
      const storedTheme = localStorage.getItem('theme');
      if (storedTheme === 'light' || storedTheme === 'dark') {
        document.documentElement.dataset.theme = storedTheme;
      }
    </script>
    <ClientRouter />
  </head>
  <body>
    <!-- GitHub-style top progress bar for client-side navigation -->
    <div id="page-loader" transition:persist="page-loader" aria-hidden="true"></div>
    <header class="sticky top-0 z-10">
      <!-- Top bar: always GitHub's dark header color, full width -->
      <div class="flex items-center justify-between bg-[#010409] px-4 py-3">
        <a
          href={base}
          class="inline-flex items-center gap-3 text-sm font-semibold text-white hover:no-underline hover:opacity-80"
        >
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-linear-to-br from-[#1f883d] to-[#0969da] text-sm font-bold text-white"
            aria-hidden="true">{site.name.charAt(0)}</span
          >
          <span>{site.handle}</span>
        </a>
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-[#9198a1]">portfolio</span>
          <button
            id="theme-toggle"
            type="button"
            class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-md border border-[#30363d] text-[#9198a1] hover:text-white"
            aria-label="Toggle color theme"
          >
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M9.5 1.3a6.9 6.9 0 1 0 5.2 9.9.5.5 0 0 0-.6-.7A5.4 5.4 0 0 1 7 3.6a5.4 5.4 0 0 1 3-1.6.5.5 0 0 0 0-.9 6.9 6.9 0 0 0-.5.2Z"/>
            </svg>
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 10.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Zm0 1.5a4 4 0 1 1 0-8 4 4 0 0 1 0 8ZM8 0a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1A.75.75 0 0 1 8 0Zm0 13.5a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1A.75.75 0 0 1 8 13.5ZM16 8a.75.75 0 0 1-.75.75h-1a.75.75 0 0 1 0-1.5h1A.75.75 0 0 1 16 8ZM2.5 8a.75.75 0 0 1-.75.75h-1a.75.75 0 0 1 0-1.5h1A.75.75 0 0 1 2.5 8Zm10.7-5.2a.75.75 0 0 1 0 1.06l-.7.7a.75.75 0 1 1-1.06-1.06l.7-.7a.75.75 0 0 1 1.06 0ZM4.56 11.44a.75.75 0 0 1 0 1.06l-.7.7A.75.75 0 0 1 2.8 12.14l.7-.7a.75.75 0 0 1 1.06 0Zm8.64 1.76a.75.75 0 0 1-1.06 0l-.7-.7a.75.75 0 0 1 1.06-1.06l.7.7a.75.75 0 0 1 0 1.06ZM4.56 4.56a.75.75 0 0 1-1.06 0l-.7-.7A.75.75 0 0 1 3.86 2.8l.7.7a.75.75 0 0 1 0 1.06Z"/>
            </svg>
          </button>
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-[#30363d] bg-linear-to-br from-[#1f883d] to-[#0969da] text-xs font-bold text-white"
            aria-hidden="true"
          >
            {site.name.split(' ').map((part) => part.charAt(0)).slice(0, 2).join('')}
          </span>
        </div>
      </div>
      <!-- Tab row: full width, icons per menu, always black like the top bar -->
      <nav class="flex gap-2 overflow-x-auto border-b border-[#30363d] bg-[#010409] px-4" aria-label="Profile sections">
        {tabs.map((tab) => (
          <a
            href={tab.href}
            class="flex items-center gap-2 whitespace-nowrap border-b-2 border-transparent px-3 pb-2.5 pt-2 text-sm leading-[23px] text-[#e6edf3] hover:border-[#30363d] hover:no-underline aria-[current=page]:border-[#f78166] aria-[current=page]:font-semibold"
            aria-current={tab.current ? 'page' : undefined}
          >
            <svg class="shrink-0 fill-[#9198a1]" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d={tab.icon} />
            </svg>
            {tab.label}
            {tab.count !== undefined && (
              <span class="rounded-full bg-white/15 px-2 text-xs font-medium leading-[18px]">{tab.count}</span>
            )}
          </a>
        ))}
      </nav>
    </header>

    <main id="overview">
      <slot />
    </main>

    <footer class="mt-10 border-t border-line py-6">
      <div class="mx-auto flex max-w-[1216px] flex-wrap justify-between gap-2 px-4 text-xs text-muted">
        <p>© {new Date().getFullYear()} {site.name}</p>
        <p>Built with Astro + Tailwind CSS · Inspired by the GitHub profile layout</p>
      </div>
    </footer>

    <script>
      // Runs on initial load AND after every client-side navigation, since
      // the ClientRouter swaps the body and all element listeners with it.
      const initPage = () => {
        // Theme toggle: flips between light and dark, starting from the
        // effective theme (stored preference or system setting)
        document.querySelector('#theme-toggle')?.addEventListener('click', () => {
          const root = document.documentElement;
          const systemDark = matchMedia('(prefers-color-scheme: dark)').matches;
          const current = root.dataset.theme ?? (systemDark ? 'dark' : 'light');
          const next = current === 'dark' ? 'light' : 'dark';
          root.dataset.theme = next;
          localStorage.setItem('theme', next);
        });
      };
      document.addEventListener('astro:page-load', initPage);

      // The router swaps <html> attributes on navigation, which would drop a
      // manually chosen theme — re-apply it right after each swap.
      document.addEventListener('astro:after-swap', () => {
        const stored = localStorage.getItem('theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.dataset.theme = stored;
        }
      });

      // GitHub-style top progress bar: crawl while the next page is being
      // fetched, then snap to 100% and fade out when it's ready.
      const loader = document.getElementById('page-loader');
      document.addEventListener('astro:before-preparation', () => {
        if (!loader) return;
        loader.dataset.loading = 'true';
        loader.style.transition = 'none';
        loader.style.width = '0';
        loader.style.opacity = '1';
        void loader.offsetWidth; // flush so the crawl animates from 0
        loader.style.transition = 'width 4s cubic-bezier(0.05, 0.6, 0.1, 1)';
        loader.style.width = '82%';
      });
      document.addEventListener('astro:page-load', () => {
        if (!loader || loader.dataset.loading !== 'true') return;
        delete loader.dataset.loading;
        loader.style.transition = 'width 0.2s ease, opacity 0.3s ease 0.25s';
        loader.style.width = '100%';
        loader.style.opacity = '0';
      });
    </script>
  </body>
</html>

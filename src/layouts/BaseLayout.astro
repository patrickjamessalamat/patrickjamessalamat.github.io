---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} (${site.handle})`,
  description = site.tagline,
} = Astro.props;

const tabs = [
  { href: '#overview', label: 'Overview' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
];

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={Astro.site ? new URL(base, Astro.site).href : base} />
    <script is:inline>
      // Apply the stored theme before first paint to avoid a flash
      const storedTheme = localStorage.getItem('theme');
      if (storedTheme === 'light' || storedTheme === 'dark') {
        document.documentElement.dataset.theme = storedTheme;
      }
    </script>
  </head>
  <body>
    <header class="sticky top-0 z-10 border-b border-line bg-canvas-subtle">
      <div class="mx-auto flex max-w-[1216px] items-center justify-between px-4 py-3">
        <a
          href={base}
          class="inline-flex items-center gap-2 text-sm font-semibold text-fg hover:text-accent hover:no-underline"
        >
          <span
            class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-linear-to-br from-btn-green to-accent text-xs font-bold text-white"
            aria-hidden="true">{site.name.charAt(0)}</span
          >
          <span>{site.handle}</span>
        </a>
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-muted">portfolio</span>
          <button
            id="theme-toggle"
            type="button"
            class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-md border border-line text-muted hover:text-fg"
            aria-label="Toggle color theme"
          >
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M9.5 1.3a6.9 6.9 0 1 0 5.2 9.9.5.5 0 0 0-.6-.7A5.4 5.4 0 0 1 7 3.6a5.4 5.4 0 0 1 3-1.6.5.5 0 0 0 0-.9 6.9 6.9 0 0 0-.5.2Z"/>
            </svg>
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 10.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Zm0 1.5a4 4 0 1 1 0-8 4 4 0 0 1 0 8ZM8 0a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1A.75.75 0 0 1 8 0Zm0 13.5a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1A.75.75 0 0 1 8 13.5ZM16 8a.75.75 0 0 1-.75.75h-1a.75.75 0 0 1 0-1.5h1A.75.75 0 0 1 16 8ZM2.5 8a.75.75 0 0 1-.75.75h-1a.75.75 0 0 1 0-1.5h1A.75.75 0 0 1 2.5 8Zm10.7-5.2a.75.75 0 0 1 0 1.06l-.7.7a.75.75 0 1 1-1.06-1.06l.7-.7a.75.75 0 0 1 1.06 0ZM4.56 11.44a.75.75 0 0 1 0 1.06l-.7.7A.75.75 0 0 1 2.8 12.14l.7-.7a.75.75 0 0 1 1.06 0Zm8.64 1.76a.75.75 0 0 1-1.06 0l-.7-.7a.75.75 0 0 1 1.06-1.06l.7.7a.75.75 0 0 1 0 1.06ZM4.56 4.56a.75.75 0 0 1-1.06 0l-.7-.7A.75.75 0 0 1 3.86 2.8l.7.7a.75.75 0 0 1 0 1.06Z"/>
            </svg>
          </button>
        </div>
      </div>
      <nav class="mx-auto flex max-w-[1216px] gap-2 overflow-x-auto px-4" aria-label="Profile sections">
        {tabs.map((tab, index) => (
          <a
            href={tab.href}
            class="whitespace-nowrap border-b-2 border-transparent px-3 pb-2.5 pt-2 text-sm leading-[23px] text-fg hover:border-line hover:no-underline aria-[current=page]:border-tab-active aria-[current=page]:font-semibold"
            data-tab
            aria-current={index === 0 ? 'page' : undefined}
          >
            {tab.label}
          </a>
        ))}
      </nav>
    </header>

    <main id="overview">
      <slot />
    </main>

    <footer class="mt-10 border-t border-line py-6">
      <div class="mx-auto flex max-w-[1216px] flex-wrap justify-between gap-2 px-4 text-xs text-muted">
        <p>© {new Date().getFullYear()} {site.name}</p>
        <p>Built with Astro + Tailwind CSS · Inspired by the GitHub profile layout</p>
      </div>
    </footer>

    <script>
      // Highlight the tab of the section currently in view. Overview is the
      // default: it wraps the whole page, so it is excluded from observation
      // and used as the fallback whenever no other section is in view.
      const tabs = [...document.querySelectorAll<HTMLAnchorElement>('[data-tab]')];
      const defaultHash = tabs[0]?.hash ?? '#overview';
      const visible = new Set<string>();

      const activate = (hash: string) => {
        for (const tab of tabs) {
          if (tab.hash === hash) tab.setAttribute('aria-current', 'page');
          else tab.removeAttribute('aria-current');
        }
      };

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) visible.add(`#${entry.target.id}`);
            else visible.delete(`#${entry.target.id}`);
          }
          const current = tabs.find((tab) => visible.has(tab.hash));
          activate(current ? current.hash : defaultHash);
        },
        { rootMargin: '-35% 0px -55% 0px' }
      );

      for (const tab of tabs.slice(1)) {
        const section = document.querySelector(tab.hash);
        if (section) observer.observe(section);
      }

      // Theme toggle: flips between light and dark, starting from the
      // effective theme (stored preference or system setting)
      document.querySelector('#theme-toggle')?.addEventListener('click', () => {
        const root = document.documentElement;
        const systemDark = matchMedia('(prefers-color-scheme: dark)').matches;
        const current = root.dataset.theme ?? (systemDark ? 'dark' : 'light');
        const next = current === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
